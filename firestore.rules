rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{docId} {
      allow get: if request.auth != null && (
        request.auth.uid == docId ||
        resource.data.email == request.auth.token.email
      );

      allow list: if request.auth != null
        && request.query.limit <= 5
        && resource.data.email == request.auth.token.email;

      allow write: if false;
    }

    match /complaints/{docId} {
      allow create: if request.resource.data.keys().hasAll([
          'trackingId', 'category', 'details', 'location', 'evidenceUrls',
          'informantName', 'informantContact', 'status', 'adminNotes',
          'createdAt', 'updatedAt'
        ])
        && request.resource.data.trackingId is string
        && request.resource.data.trackingId.matches('CR-[0-9]+')
        && request.resource.data.status == 'รอดำเนินการ'
        && request.resource.data.adminNotes == ''
        && request.resource.data.evidenceUrls is list
        && request.resource.data.location is map
        && request.resource.data.location.keys().hasAll([
          'address', 'district', 'subDistrict', 'province'
        ])
        && request.resource.data.location.province == 'เชียงราย'
        && request.resource.data.location.address is string
        && request.resource.data.location.district is string
        && request.resource.data.location.subDistrict is string
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow read: if true;

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'adminNotes', 'updatedAt']);

      allow delete: if isAdmin();
    }
  }
}
